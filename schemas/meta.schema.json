{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://raw.githubusercontent.com/gibson9583/oie-community-catalog/main/schemas/meta.schema.json",
    "title": "OIE Community Catalog package metadata (manifests/<id>/meta.json)",
    "type": "object",
    "required": ["id", "name", "description", "type", "publisher", "repository", "license"],
    "additionalProperties": true,
    "properties": {
        "id": {
            "description": "Stable package id (directory name). For extensions this MUST equal the plugin.xml path attribute.",
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "type": {
            "type": "string",
            "enum": ["plugin", "connector", "datatype", "channel", "code-template", "code-template-library"]
        },
        "publisher": { "type": "string", "minLength": 1 },
        "repository": { "type": "string", "format": "uri", "description": "Source repository URL (any forge)." },
        "homepage": { "type": "string", "format": "uri" },
        "documentation": { "type": "string", "format": "uri" },
        "license": { "type": "string", "description": "SPDX identifier or expression." },
        "authors": { "type": "array", "items": { "type": "string" } },
        "keywords": { "type": "array", "items": { "type": "string" } },
        "deprecated": { "type": "boolean", "default": false },
        "deprecationMessage": { "type": "string" },
        "contentId": {
            "description": "REQUIRED for channel / code-template / code-template-library packages: the engine id (UUID) inside the artifact, used for installed-detection.",
            "type": "string",
            "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
        }
    }
}
